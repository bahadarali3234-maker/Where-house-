{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A project or application stored in the warehouse.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string", "enum": ["Entertainment & Games", "Utility & Web Tools", "Lab & Experiments"] },
        "techStack": { "type": "array", "items": { "type": "string" } },
        "link": { "type": "string", "format": "uri" },
        "isFeatured": { "type": "boolean" },
        "size": { "type": "string", "enum": ["small", "medium", "large"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "category", "link", "size"]
    },
    "Admin": {
      "title": "Admin",
      "description": "User with management privileges.",
      "type": "object",
      "properties": {
        "email": { "type": "string" }
      },
      "required": ["email"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of all apps and projects."
    },
    "/admins/{adminId}": {
      "schema": "Admin",
      "description": "List of authorized administrators."
    }
  }
}
